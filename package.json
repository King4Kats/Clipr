{
  "name": "clipr",
  "version": "2.0.0",
  "description": "Segmentation vidéo intelligente par IA — Application web Docker",
  "scripts": {
    "dev:web": "concurrently \"npx tsx server/index.ts\" \"npx vite --config vite.config.ts\"",
    "build:web": "npx vite build --config vite.config.ts",
    "start:web": "npx tsx server/index.ts",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f clipr",
    "test": "vitest run"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "multer": "^1.4.5-lts.1",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zustand": "^4.4.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/react-grid-layout": "^1.3.6",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^4.0.18"
  }
}
