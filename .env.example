# Clipr - Environment Variables
# Copy this file to .env and fill in the values

# JWT secret for authentication (REQUIRED - generate a strong random string)
# Example: openssl rand -hex 32
JWT_SECRET=

# Cloudflare Tunnel token (required for tunnel service)
CLOUDFLARE_TUNNEL_TOKEN=

# Domain name for Caddy reverse proxy (default: localhost)
CLIPR_DOMAIN=localhost
