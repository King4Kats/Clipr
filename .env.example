# Clipr — Variables d'environnement
# Copier ce fichier en .env et remplir avec vos vraies valeurs.
# Le .env est gitignore et ne doit JAMAIS etre commite.

# ── Authentification ────────────────────────────────────────────
# Cle secrete pour signer les tokens JWT.
# A generer aleatoirement, 32+ caracteres. Exemple :
#   openssl rand -hex 32
# IMPORTANT : changer cette valeur invalide toutes les sessions existantes.
JWT_SECRET=remplacer-par-une-cle-aleatoire-de-32-caracteres-minimum

# ── Hugging Face ────────────────────────────────────────────────
# Token requis pour telecharger certains modeles (diarisation pyannote).
# A creer sur https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare Tunnel (optionnel) ───────────────────────────────
# Token du tunnel pour exposer l'app via Cloudflare.
# Laisser vide si vous n'utilisez pas de tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# ── CORS (production) ───────────────────────────────────────────
# Domaines autorises a appeler l'API. Separer par virgule.
# Exemple : https://clipr.mon-domaine.fr
CORS_ORIGINS=*
